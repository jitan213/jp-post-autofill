{
  "manifest_version": 3,
  "name": "国際郵便マイページ 住所オートフィル",
  "version": "1.14.0",
  "description": "eBayなどからコピーした住所ブロックを貼り付けると、国際郵便マイページのお届け先入力フォームに自動入力します。",
  "key": "",
  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.int-mypage.post.japanpost.jp/*",
    "https://int-mypage.post.japanpost.jp/*",
    "http://localhost:3999/*",
    "http://127.0.0.1:3999/*",
    "http://100.93.41.106:3999/*",
    "https://github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://objects.githubusercontent.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "住所オートフィル",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.int-mypage.post.japanpost.jp/*",
        "https://int-mypage.post.japanpost.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}